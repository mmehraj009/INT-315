# ============================================
# University Dropout Prediction (FINAL WORKING)
# PySpark - Windows Stable Version
# ============================================

from pyspark.sql import SparkSession
from pyspark.sql.functions import col
from pyspark.ml.feature import StringIndexer, VectorAssembler
from pyspark.ml.classification import RandomForestClassifier
from pyspark.ml.evaluation import BinaryClassificationEvaluator, MulticlassClassificationEvaluator
import matplotlib.pyplot as plt

# --------------------------------------------
# 1. Spark Session (FIXED FOR WINDOWS)
# --------------------------------------------
spark = SparkSession.builder \
    .appName("University Dropout Prediction") \
    .master("local[1]") \
    .config("spark.python.worker.reuse", "false") \
    .config("spark.driver.host", "127.0.0.1") \
    .config("spark.driver.bindAddress", "127.0.0.1") \
    .getOrCreate()

# --------------------------------------------
# 2. Create Sample Dataset
# --------------------------------------------
data = [
    (1, "Male", "North", "Science", 85, 90, 0),
    (2, "Female", "South", "Arts", 60, 55, 1),
    (3, "Male", "East", "Commerce", 70, 65, 0),
    (4, "Female", "West", "Science", None, 50, 1),
    (5, "Male", "North", "Arts", 40, None, 1),
    (6, "Female", "South", "Commerce", 88, 92, 0),
    (7, "Male", "East", "Science", 95, 96, 0),
    (8, "Female", "West", "Arts", 55, 60, 1),
    (9, "Male", "North", "Commerce", 78, 80, 0),
    (10, "Female", "South", "Science", 30, 40, 1)
]

columns = ["student_id", "gender", "region", "program", "attendance", "grade", "dropout"]

df = spark.createDataFrame(data, columns)

print("=== ORIGINAL DATA ===")
df.show()

# --------------------------------------------
# 3. Data Cleaning (Fill Missing Values)
# --------------------------------------------
avg_attendance = df.selectExpr("avg(attendance)").first()[0]
avg_grade = df.selectExpr("avg(grade)").first()[0]

df = df.fillna({
    "attendance": avg_attendance,
    "grade": avg_grade
})

print("=== CLEANED DATA ===")
df.show()

# --------------------------------------------
# 4. Feature Transformation
# --------------------------------------------
gender_indexer = StringIndexer(inputCol="gender", outputCol="gender_index")
region_indexer = StringIndexer(inputCol="region", outputCol="region_index")
program_indexer = StringIndexer(inputCol="program", outputCol="program_index")

df = gender_indexer.fit(df).transform(df)
df = region_indexer.fit(df).transform(df)
df = program_indexer.fit(df).transform(df)

assembler = VectorAssembler(
    inputCols=["gender_index", "region_index", "program_index", "attendance", "grade"],
    outputCol="features"
)

df = assembler.transform(df)

# --------------------------------------------
# 5. Train-Test Split
# --------------------------------------------
train_df, test_df = df.randomSplit([0.8, 0.2], seed=42)

# --------------------------------------------
# 6. Train Random Forest Model
# --------------------------------------------
rf = RandomForestClassifier(
    featuresCol="features",
    labelCol="dropout",
    numTrees=20
)

model = rf.fit(train_df)

# --------------------------------------------
# 7. Predictions
# --------------------------------------------
predictions = model.transform(test_df)

print("=== PREDICTIONS ===")
predictions.select("student_id", "dropout", "prediction", "probability").show()

# --------------------------------------------
# 8. Evaluation
# --------------------------------------------
roc_eval = BinaryClassificationEvaluator(
    labelCol="dropout",
    metricName="areaUnderROC"
)

f1_eval = MulticlassClassificationEvaluator(
    labelCol="dropout",
    metricName="f1"
)

roc_auc = roc_eval.evaluate(predictions)
f1_score = f1_eval.evaluate(predictions)

print(f"ROC-AUC: {roc_auc:.3f}")
print(f"F1 Score: {f1_score:.3f}")

# --------------------------------------------
# 9. Visualization
# --------------------------------------------
counts = df.groupBy("dropout").count().collect()

labels = ["Retained", "Dropped Out"]
values = [row["count"] for row in counts]

plt.figure()
plt.bar(labels, values)
plt.title("Dropout vs Retained Students")
plt.xlabel("Category")
plt.ylabel("Count")
plt.show()

# --------------------------------------------
# Stop Spark
# --------------------------------------------
spark.stop()
